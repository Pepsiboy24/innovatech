{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/public/html/login.html"
    },
    {
      "source": "/signup",
      "destination": "/public/html/signup.html"
    },
    {
      "source": "/admin",
      "destination": "/portals/admin/schoolAdminDashboard.html"
    },
    {
      "source": "/admin/:page",
      "destination": "/portals/admin/:page.html"
    },
    {
      "source": "/teacher",
      "destination": "/portals/teacher/teachersPortal.html"
    },
    {
      "source": "/teacher/:page",
      "destination": "/portals/teacher/:page.html"
    },
    {
      "source": "/parent",
      "destination": "/portals/parent/parentsPortal.html"
    },
    {
      "source": "/parent/:page",
      "destination": "/portals/parent/:page.html"
    },
    {
      "source": "/student",
      "destination": "/portals/student/studentPortal.html"
    },
    {
      "source": "/student/:page",
      "destination": "/portals/student/:page.html"
    }
  ]
}